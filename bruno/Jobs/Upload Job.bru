meta {
  name: Upload Job
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/jobs
  body: multipartForm
  auth: none
}

body:multipart-form {
  image: @file(C:\Users\Ronit\OneDrive\Pictures\Screenshots\Screenshot 2026-07-07 173344.png) @contentType(image/png)
}

script:post-response {
  if (res.body?.result?.job_id) {
    bru.setVar("job_id", res.body.result.job_id);
  }
}
