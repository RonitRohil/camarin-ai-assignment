PORT=5002
DEVELOPMENT=True
CORS_ORIGIN=http://localhost:5173

# Postgres (matches docker-compose's postgres service; adjust if running Postgres locally instead)
DATABASE_URL=postgresql://camarin:camarin@localhost:5432/camarin_ai?schema=public

# JWT (access + refresh, per ADR-4 - httpOnly cookies, two separate secrets)
# generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-generated-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-generated-random-secret

# Storage (per ADR-3 - local bind mount for dev, R2 for deployed)
# STORAGE_DRIVER=r2 switches to Cloudflare R2 and requires the R2_* vars below
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./uploads
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=your-r2-bucket-name

# Redis / BullMQ queue (per ADR-2; matches docker-compose's redis service)
REDIS_URL=redis://localhost:6379

# AI pipeline
# CAPTION_DRIVER=local (default) - self-hosted in-process model (see pipeline/caption.pipeline.js),
#   HF_ACCESS_TOKEN not required for the public model it downloads
# CAPTION_DRIVER=api - routes through Hugging Face's Inference Providers (see
#   pipeline/caption.api.pipeline.js), for deployments too memory-constrained for the local model.
#   Requires HF_ACCESS_TOKEN and the featherless-ai provider enabled at
#   huggingface.co/settings/inference-providers
CAPTION_DRIVER=local
HF_ACCESS_TOKEN=your-hugging-face-access-token
# Vision API key - see README for how to obtain (GCP project, enable billing + Cloud Vision API)
GOOGLE_VISION_API_KEY=your-google-vision-api-key
# Where self-hosted model weights are cached (outside node_modules, so npm install doesn't wipe it)
MODEL_CACHE_DIR=./.cache/models

# Combined mode - starts the worker in-process after the API server boots (see src/index.js).
# Needed for single-service deployment targets (e.g. Render free tier) that can't run a
# separate worker process. Leave unset/false for docker-compose, where worker runs standalone.
COMBINED_MODE=false